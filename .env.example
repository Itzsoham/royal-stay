# Copy this file to ".env" and fill in your values.
# Vite only exposes variables prefixed with VITE_ to the browser.

# Neon Auth — Console > Auth  (e.g. https://ep-aged-truth-ao1j9m9f...neon.tech/neondb/auth)
VITE_NEON_AUTH_URL=

# Neon Data API — Console > Data API  (e.g. https://ep-aged-truth-ao1j9m9f...neon.tech/neondb/rest/v1)
VITE_NEON_DATA_API_URL=

# Cloudinary — Settings > Upload > Add upload preset (Unsigned)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
